# Normalize line endings to LF in the repo; checkout as-is on each OS
* text=auto eol=lf

# Shell scripts must stay LF even on Windows
android-agent/gradlew text eol=lf

# Binary files — no line-ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.apk binary
*.aab binary
*.keystore binary
*.jks binary
*.jar binary
*.zip binary
android-agent/gradle/wrapper/gradle-wrapper.jar binary
